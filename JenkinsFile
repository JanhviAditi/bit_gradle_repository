pipeline {
    agent any

    tools {
        jdk 'JDK'
        gradle 'gradle'
    }

    stages {

        stage('Build') {
            steps {
                bat 'gradle build'
            }
        }

        stage('Test') {
            steps {
                bat 'gradle test'
            }
        }

        stage('Package') {
            steps {
                bat 'gradle assemble'
            }
        }
        stage('Run') {
            steps {
                bat 'gradle run'
            }
        }
    }

    post {
        success {
            echo 'Build Successful'
        }
        failure {
            echo 'Build Failed'
        }
    }
}
